{
  "manifest_version": 3,
  "name": "Localhost Public URL",
  "version": "1.0.0",
  "description": "Generate secure public URLs for your local development server instantly.",

  "action": {
    "default_popup": "popup.html",
    "default_title": "Localhost Public URL"
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "permissions": [
    "tabs",
    "storage",
    "nativeMessaging"
  ],

  "host_permissions": [
    "http://127.0.0.1:54321/*"
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_security_policy": {
    "extension_pages": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; connect-src http://127.0.0.1:54321/"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "localhostpublicurl@yourdomain.com",
      "strict_min_version": "109.0"
    }
  }
}